# Android signing key and passwords - NEVER commit these. Losing them
# doesn't matter (they're backed up separately), but leaking them publicly
# would let anyone sign a malicious update that looks like it came from us.
android-twa/android.keystore
android-twa/keystore-credentials.txt

# Build artifacts - regenerated by `gradlew assembleRelease` + apksigner,
# not meant to live in git. Published releases go to GitHub Releases instead.
android-twa/app-release-signed.apk
android-twa/app-release-signed.apk.idsig
android-twa/app-release-unsigned.apk
android-twa/app/build/
android-twa/build/
android-twa/.gradle/
android-twa/gradle_build*.log
android-twa/build_ps.log
android-twa/manifest-checksum.txt

# Machine-specific SDK path, not portable across machines
android-twa/local.properties
